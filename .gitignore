# .gitignore — synaptix-workspace
# This repo tracks workspace-level files ONLY.
# Each project below is its own independent git repository.

# ── Project directories (each has its own git repo) ──────────────────────────
/Papyrus/
/project-refiner/
/happyseniors/
/nightingale/
/website/
/ARCHIVE/
/_platform/synaptix-sdk/
/_platform/synaptix-scaffold/
/_platform/youtube-api/
/agents/
/family-finance/
/temp/
/gemini-cli/

# ── OS & Editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/

# ── Secrets (never commit) ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
